@model List<DivaSalon.Models.Order>
@{
    ViewData["Title"] = "Comenzile Mele - DivaSalon";
}

<div class="my-orders-container">
    <div class="orders-header">
        <h1>Comenzile Mele</h1>
        <p>Istoricul programarilor tale la DivaSalon</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-orders">
            <h3>Nu ai nicio programare</h3>
            <p>Fa-ti prima programare acum!</p>
            <a href="/Orders/Create" class="btn btn-primary">Programeaza-te</a>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in Model)
            {
                <div class="order-card">
                    <div class="order-header-info">
                        <div class="order-id">Comanda #@order.Id</div>
                        <div class="order-status">Status: @order.Status.ToString()</div>
                    </div>
                    <div class="order-details">
                        <div>Data: @order.AppointmentDate.ToString("dd MMMM yyyy, HH:mm")</div>
                        <div>Specialist: @(order.Barber?.FullName ?? "Necunoscut")</div>
                        <div>Total: @order.TotalAmount MDL</div>
                    </div>
                    <div class="order-actions">
                        @if (order.Status == DivaSalon.Models.OrderStatus.Pending)
                        {
                            <a href="/Orders/Cancel?id=@order.Id" class="btn btn-danger" onclick="return confirm('Sigur anulezi?')">Anuleaza</a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .my-orders-container {
        max-width: 1000px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .orders-header {
        text-align: center;
        margin-bottom: 2rem;
    }

        .orders-header h1 {
            color: #FFDAB9;
            margin-bottom: 0.5rem;
        }

    .empty-orders {
        text-align: center;
        padding: 4rem;
        background: #2d2d2d;
        border-radius: 20px;
    }

    .orders-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .order-card {
        background: #2d2d2d;
        border-radius: 15px;
        padding: 1.5rem;
        border: 1px solid rgba(255, 218, 185, 0.2);
    }

    .order-header-info {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .order-id {
        font-weight: bold;
    }

    .order-details {
        margin-bottom: 1rem;
    }

        .order-details div {
            margin-bottom: 0.5rem;
        }

    .btn-danger {
        background: #e74c3c;
        color: white;
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary {
        background: linear-gradient(135deg, #FFDAB9, #e6c4a6);
        color: #1a1a1a;
        padding: 10px 20px;
        border-radius: 25px;
        text-decoration: none;
        display: inline-block;
    }

    @@media (max-width: 768px) {
        .order-card {
            padding: 1rem;
        }

        .order-header-info {
            flex-direction: column;
            gap: 0.5rem;
        }
    }
</style>
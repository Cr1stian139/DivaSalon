@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes" />
    <meta name="theme-color" content="#FFDAB9" />
    <title>@ViewData["Title"] - DivaSalon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="logo">
                <img src="/images/logo/logo.png" alt="DivaSalon" class="logo-img" />
                <span class="logo-text">DivaSalon</span>
            </a>
            <ul class="nav-menu">
                <li><a href="/" class="nav-link">Acasa</a></li>
                <li><a href="/Services" class="nav-link">Servicii</a></li>
                <li><a href="/Barbers" class="nav-link">Specialisti</a></li>
                <li><a href="/Orders/Create" class="nav-link">Programare</a></li>
                <li><a href="/Contact" class="nav-link">Contact</a></li>
            
                @if (SignInManager.IsSignedIn(User))
                {
                    @if (User.IsInRole("Admin") || User.IsInRole("Barber"))
                    {
                        <li><a href="/Admin/Dashboard" class="nav-link">Dashboard</a></li>
                    }
                    <li><a href="/Orders/MyOrders" class="nav-link">Comenzile mele</a></li>
                    <li>
                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="display: inline;">
                            <button type="submit" class="nav-link" style="background: none; border: none; cursor: pointer;">Logout</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a href="/Identity/Account/Login" class="nav-link">Login</a></li>
                    <li><a href="/Identity/Account/Register" class="nav-link">Inregistrare</a></li>
                }
            </ul>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-container">
            <div class="footer-section">
                <div class="footer-logo">
                    <img src="/images/logo/logo.png" alt="DivaSalon" class="footer-logo-img" />
                    <h3>DivaSalon</h3>
                </div>
                <p class="footer-description">Frizerie premium in inima orasului. Oferim servicii de calitate intr-un ambient placut si modern.</p>
            </div>
            
            <div class="footer-section">
                <h4><span class="icon"></span> Program de lucru</h4>
                <ul class="footer-schedule">
                    <li><span class="day">Luni:</span><span class="hours">Inchis</span></li>
                    <li><span class="day">Marti - Sambata:</span><span class="hours">08:00 - 18:00</span></li>
                    <li><span class="day">Duminica:</span><span class="hours">08:00 - 15:00</span></li>
                </ul>
            </div>
            
            <div class="footer-section">
                <h4><span class="icon">📍</span> Contact</h4>
                <ul class="footer-contact">
                    <li><span class="contact-icon"></span> <a href="tel:060844660">0608 44 660</a></li>
                    <li><span class="contact-icon"></span> <a href="mailto:olgamotelica123@gmail.com">olgamotelica123@gmail.com</a></li>
                    <li><span class="contact-icon"></span> <span>31 August 1989 4i, Cahul, Moldova</span></li>
                </ul>
            </div>
            
            <div class="footer-section">
                <h4><span class="icon"></span> Link-uri rapide</h4>
                <ul class="footer-links">
                    <li><a href="/">Acasa</a></li>
                    <li><a href="/Services">Servicii</a></li>
                    <li><a href="/Barbers">Specialisti</a></li>
                    <li><a href="/Orders/Create">Programare</a></li>
                    <li><a href="/Contact">Contact</a></li>
                </ul>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>&copy; 2026 DivaSalon - Toate drepturile rezervate. Creat cu <span class="heart">❤️</span> pentru clientii nostri.</p>
        </div>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>